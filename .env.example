# Supabase — copy to .env.local and fill with values from your Supabase project
# (Project Settings → API). NEXT_PUBLIC_ vars are exposed in the browser bundle,
# which is correct for the URL and the anon (public) key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Google Places API (New) — SERVER-ONLY key (no NEXT_PUBLIC_ prefix, never sent to
# the browser). Powers the admin "Discover suppliers" panel via /api/suppliers/discover.
# Enable "Places API (New)" in Google Cloud, restrict the key to that API, and set a
# budget cap. Leave blank to keep the feature inert.
GOOGLE_PLACES_API_KEY=
